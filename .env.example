# Backend environment variables
COPILOT_GITHUB_TOKEN=ghp_your_token_here
# COPILOT_CLI_PATH=copilot

# Work IQ (optional - attach Work IQ MCP server to Copilot session)
WORKIQ_ENABLED=true

# BYOK - Bring Your Own Key (alternative to GitHub Copilot subscription)
# BYOK_PROVIDER=azure  # openai | azure | anthropic
# BYOK_API_KEY=your_api_key
# BYOK_BASE_URL=https://your-resource.openai.azure.com
# BYOK_MODEL=gpt-4o
# BYOK_AZURE_API_VERSION=2024-10-21

# Backend server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
